    @State private var intentionalWalks = ""
    @State private var hitByPitch = ""
    @State private var sacrificeFlies = ""

    let onSave: (Hitter) -> Void

    private var canSave: Bool {
        name.isEmpty == false &&
        team.isEmpty == false &&
        teamAbbreviation.isEmpty == false &&
        position.isEmpty == false &&
        intValue(for: plateAppearances) > 0
    }

    var body: some View {
        NavigationStack {
            Form {
                Section("Player") {
                    TextField("Name", text: $name)
                    TextField("Team", text: $team)
                    TextField("Team Abbreviation", text: $teamAbbreviation)
                    TextField("Position", text: $position)
                    TextField("Park Factor", text: $parkFactor)
                        .keyboardType(.decimalPad)
                }

                Section("Batting Inputs") {
                    statField("Plate Appearances", text: $plateAppearances)
                    statField("At Bats", text: $atBats)
                    statField("Hits", text: $hits)
                    statField("Doubles", text: $doubles)
                    statField("Triples", text: $triples)
                    statField("Home Runs", text: $homeRuns)
                    statField("Walks", text: $walks)
                    statField("Intentional Walks", text: $intentionalWalks)
                    statField("Hit By Pitch", text: $hitByPitch)
                    statField("Sacrifice Flies", text: $sacrificeFlies)
                }
            }
            .navigationTitle("Add Hitter")
            .toolbar {
                ToolbarItem(placement: .cancellationAction) {
                    Button("Cancel") {
                        dismiss()
                    }
                }

                ToolbarItem(placement: .confirmationAction) {
                    Button("Save") {
                        onSave(makeHitter())
                        dismiss()
                    }
                    .disabled(canSave == false)
                }
            }
        }
    }

    private func statField(_ title: String, text: Binding<String>) -> some View {
        TextField(title, text: text)
            .keyboardType(.numberPad)
    }

    private func intValue(for string: String) -> Int {
        Int(string) ?? 0
    }

    private func doubleValue(for string: String, fallback: Double) -> Double {
        Double(string) ?? fallback
    }

    private func makeHitter() -> Hitter {
        Hitter(
            name: name,
            team: team,
            teamAbbreviation: teamAbbreviation.uppercased(),
            position: position.uppercased(),
            parkFactor: doubleValue(for: parkFactor, fallback: 1.000),
            stats: HitterStats(
                plateAppearances: intValue(for: plateAppearances),
                atBats: intValue(for: atBats),
                hits: intValue(for: hits),
                doubles: intValue(for: doubles),
                triples: intValue(for: triples),
                homeRuns: intValue(for: homeRuns),
                walks: intValue(for: walks),
                intentionalWalks: intValue(for: intentionalWalks),
                hitByPitch: intValue(for: hitByPitch),
                sacrificeFlies: intValue(for: sacrificeFlies)
            )
        )
    }
}

