        }
        .padding(20)
        .frame(maxWidth: .infinity, alignment: .leading)
        .appCard()
    }

    private func pullUpPlayersToCompare(matching query: String) -> [Hitter] {
        guard query.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty == false else {
            return []
        }

        return hitters.filter { hitter in
            hitter.name.localizedCaseInsensitiveContains(query) ||
            hitter.team.localizedCaseInsensitiveContains(query) ||
            hitter.teamAbbreviation.localizedCaseInsensitiveContains(query) ||
            hitter.position.localizedCaseInsensitiveContains(query)
        }
    }

    private func toggleComparison(for hitter: Hitter) {
        if let index = selectedComparisonIDs.firstIndex(of: hitter.id) {
            selectedComparisonIDs.remove(at: index)
            return
        }

        selectedComparisonIDs.append(hitter.id)
    }

