extension PlayerTier {
    var color: Color {
        switch self {
        case .aboveAverage:
            return .successGreen
        case .average:
            return .warningGold
        case .belowAverage:
            return .dangerRed
        }
    }
}

extension Color {
    static let successGreen = Color(red: 0.11, green: 0.74, blue: 0.45)
    static let warningGold = Color(red: 0.96, green: 0.74, blue: 0.17)
    static let dangerRed = Color(red: 0.98, green: 0.28, blue: 0.20)
    static let appNavy = Color(red: 0.03, green: 0.09, blue: 0.20)
    static let appBlue = Color(red: 0.06, green: 0.15, blue: 0.32)
    static let appInk = Color(red: 0.02, green: 0.05, blue: 0.12)
    static let panelFill = Color(red: 0.07, green: 0.12, blue: 0.24).opacity(0.94)
    static let playerFill = Color(red: 0.05, green: 0.10, blue: 0.20).opacity(0.92)
}

enum AppCardStyle {
    case highlight
    case panel
    case player

    var fill: Color {
        switch self {
        case .highlight:
            return .white.opacity(0.10)
        case .panel:
            return .panelFill
        case .player:
            return .playerFill
        }
    }

    var strokeOpacity: Double {
        self == .highlight ? 0.12 : 0.10
    }
}

struct AppBackground<Content: View>: View {
    @ViewBuilder let content: Content

    var body: some View {
        ZStack {
            LinearGradient(
                colors: [.appNavy, .appBlue, .appInk],
                startPoint: .topLeading,
                endPoint: .bottomTrailing
            )
            .ignoresSafeArea()

            content
        }
    }
}

extension View {
    func appCard(_ style: AppCardStyle = .panel) -> some View {
        background(
            RoundedRectangle(cornerRadius: 24, style: .continuous)
                .fill(style.fill)
                .overlay(
                    RoundedRectangle(cornerRadius: 24, style: .continuous)
                        .stroke(.white.opacity(style.strokeOpacity), lineWidth: 1)
                )
        )
    }
}

