import SwiftUI

enum PlayerTier: String, CaseIterable {
    case aboveAverage = "Above Avg"
    case average = "Average"
    case belowAverage = "Below Avg"
}

struct LeagueConstants {
    let leagueWOBA: Double
    let wobaScale: Double
    let walkWeight: Double
    let hitByPitchWeight: Double
    let singleWeight: Double
    let doubleWeight: Double
    let tripleWeight: Double
    let homeRunWeight: Double
    let leagueRunsPerPlateAppearance: Double

    static let mlb2024 = LeagueConstants(
        leagueWOBA: 0.310,
        wobaScale: 1.242,
        walkWeight: 0.689,
        hitByPitchWeight: 0.720,
        singleWeight: 0.882,
        doubleWeight: 1.254,
        tripleWeight: 1.590,
        homeRunWeight: 2.050,
        leagueRunsPerPlateAppearance: 0.117
    )
}

struct HitterStats {
    let plateAppearances: Int
    let atBats: Int
    let hits: Int
    let doubles: Int
    let triples: Int
    let homeRuns: Int
    let walks: Int
    let intentionalWalks: Int
    let hitByPitch: Int
    let sacrificeFlies: Int

    var singles: Int {
        max(0, hits - doubles - triples - homeRuns)
    }
}

struct Hitter: Identifiable {
    let id = UUID()
    let name: String
    let team: String
    let teamAbbreviation: String
    let position: String
    let parkFactor: Double
    let stats: HitterStats

    var weightedOnBaseAverage: Double {
        let constants = LeagueConstants.mlb2024
        let unintentionalWalks = stats.walks - stats.intentionalWalks
        let denominator = Double(
            stats.atBats +
            stats.walks -
            stats.intentionalWalks +
            stats.sacrificeFlies +
            stats.hitByPitch
        )

        let numerator =
            constants.walkWeight * Double(unintentionalWalks) +
            constants.hitByPitchWeight * Double(stats.hitByPitch) +
            constants.singleWeight * Double(stats.singles) +
            constants.doubleWeight * Double(stats.doubles) +
            constants.tripleWeight * Double(stats.triples) +
            constants.homeRunWeight * Double(stats.homeRuns)

        guard denominator > 0 else {
            return 0
        }

        return numerator / denominator
    }

    var weightedRunsAboveAverage: Double {
        let constants = LeagueConstants.mlb2024
        return ((weightedOnBaseAverage - constants.leagueWOBA) / constants.wobaScale) * Double(stats.plateAppearances)
    }

    var weightedRunsCreatedPlus: Int {
        let constants = LeagueConstants.mlb2024
        let plateAppearances = Double(stats.plateAppearances)

        guard plateAppearances > 0 else {
            return 0
        }

        let playerRunsPerPA = weightedRunsAboveAverage / plateAppearances
        let parkAdjustment = constants.leagueRunsPerPlateAppearance - (parkFactor * constants.leagueRunsPerPlateAppearance)
        let value = (((playerRunsPerPA + constants.leagueRunsPerPlateAppearance) + parkAdjustment) / constants.leagueRunsPerPlateAppearance) * 100
        return Int(value.rounded())
    }

    var tier: PlayerTier {
        if (95...105).contains(weightedRunsCreatedPlus) {
            return .average
        } else if weightedRunsCreatedPlus > 105 {
            return .aboveAverage
        } else {
            return .belowAverage
        }
    }

    var accentColor: Color {
        tier.color
    }

    var formattedWOBA: String {
        String(format: "%.3f", weightedOnBaseAverage)
    }
}

