        let sortedHitters = groupHitters.sorted { $0.weightedRunsCreatedPlus > $1.weightedRunsCreatedPlus }
        return (sortedHitters.firstIndex { $0.id == hitter.id } ?? 0) + 1
    }

    private var deltaFromGroupAverage: Int {
        hitter.weightedRunsCreatedPlus - Int(groupAverageWRCPlus.rounded())
